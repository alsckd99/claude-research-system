{
  "name": "claude-research-system",
  "version": "1.2.0",
  "description": "Autonomous ML R&D loop — project bootstrap, literature search, experiment running, failure analysis, and policy evolution.",
  "agents": "agents/",
  "skills": "skills/",
  "hooks": "hooks/hooks.json",
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(pytest*)",
      "Bash(ruff*)",
      "Bash(black*)",
      "Bash(conda*)",
      "Bash(uv*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git pull)",
      "Bash(make*)",
      "Bash(mkdir*)",
      "Bash(cp*)",
      "Bash(mv*)",
      "Bash(jq*)"
    ],
    "deny": [
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(git clean -f*)"
    ]
  },
  "mcpServers": {
    "arxiv": {
      "command": "uvx",
      "args": ["arxiv-mcp-server"],
      "description": "arXiv paper search, download, and full-text reading via dedicated MCP tools (search_papers, download_paper, read_paper)"
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "description": "Semantic Scholar and OpenAlex API calls, general HTTP access"
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_TOKEN": "${GITHUB_TOKEN}"
      },
      "description": "GitHub PR, issue, and branch management (optional)"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "${BRAVE_API_KEY}"
      },
      "description": "Web search for benchmark leaderboards, GitHub repos, and official docs (optional)"
    }
  }
}
